diff --git a/shim/shim.go b/shim/shim.go
new file mode 100644
index 0000000..91861d9
--- /dev/null
+++ b/shim/shim.go
@@ -0,0 +1,14 @@
+// Package shim exposes the terraform-plugin-framework Mailgun provider from a
+// non-internal package so it can be consumed by the Pulumi bridge.
+package shim
+
+import (
+	"github.com/hashicorp/terraform-plugin-framework/provider"
+
+	"github.com/wgebis/terraform-provider-mailgun/internal/framework"
+)
+
+// NewProvider returns the terraform-plugin-framework provider implementation.
+func NewProvider() provider.Provider {
+	return framework.New()()
+}
